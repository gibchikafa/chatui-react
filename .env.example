PORT=3001

# Base path when running behind a reverse proxy.
# On Hopsworks this is derived automatically from HOPSWORKS_PROJECT_NAME
# and HOPSWORKS_JOB_NAME — you do not need to set BASE_PATH there.
# For other environments set it explicitly, e.g. /myapp/
# BASE_PATH=/

# Single-agent setup via env vars (used when agents.json does not exist)
BACKEND_AGENT_URL=http://your-host/v1/endpoint
BACKEND_AGENT_API_KEY=your-api-key
BACKEND_AGENT_NAME=RAG Agent
BACKEND_AGENT_ID=default
