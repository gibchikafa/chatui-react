PORT=3001

# Base path when running behind a reverse proxy (e.g. /v1/g2/myapp/)
# Must match the path the proxy strips before forwarding to this server.
# Leave as / for local dev or when the proxy strips the prefix for you.
BASE_PATH=/

# Single-agent setup via env vars (used when agents.json does not exist)
BACKEND_AGENT_URL=http://your-host/v1/endpoint
BACKEND_AGENT_API_KEY=your-api-key
BACKEND_AGENT_NAME=RAG Agent
BACKEND_AGENT_ID=default
